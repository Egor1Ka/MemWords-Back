# MemWords backend env. Copy to .env for local dev; in production this file is
# generated on the server from GitHub Secrets by the deploy workflow.

# Core
DB_URL=mongodb://127.0.0.1:27017/memwords
PORT=9000
API_PREFIX=/api

# Auth / JWT
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_DAYS=7

# Cookies (local dev over http -> false; production https -> true)
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# CORS / OAuth targets
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:9000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Media (Cloudinary)
MEDIA_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
